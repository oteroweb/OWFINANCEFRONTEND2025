VITE_API_BASE_URL=https://owfinances.com/api/v1
VITE_API_KEY=tu_token_fijo_o_api_key

# Sentry — dejar vacío para desactivar en dev
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# Feature flags — 1=activado, 0=desactivado (default en useFeatureFlags.ts)
VITE_FF_ADVISOR=1
VITE_FF_DREAMS=1
VITE_FF_PRO_MODE=1
VITE_FF_BULK_IMPORT=1
VITE_FF_ANDROID=0
