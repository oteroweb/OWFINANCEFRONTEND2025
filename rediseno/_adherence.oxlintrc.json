{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "cantaros-mobile/**",
              "color-scheme.js",
              "marketing.js",
              "onboarding/**",
              "period-selector.js",
              "ui_kits/lite-desktop/**",
              "ui_kits/lite-desktop/atoms/**",
              "ui_kits/lite-desktop/data/**",
              "ui_kits/lite-desktop/molecules/**",
              "ui_kits/lite-desktop/organisms/**",
              "ui_kits/lite-desktop/shells/**",
              "ui_kits/lite-desktop/templates/**",
              "ui_kits/mobile/**",
              "ui_kits/mobile/components/**",
              "ui_kits/mobile/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Satoshi|DM Sans|Manrope|Inter))/i]",
        "message": "Font not provided by the design system. Available: Satoshi, DM Sans, Manrope, Inter."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
